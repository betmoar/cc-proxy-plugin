# Copy to `.env` and fill in. Loaded automatically by `bin/cc-proxy.js` when
# present (Node 22 process.loadEnvFile). For the Claude Code plugin flow, these
# go in ~/.claude/settings.json `env` instead — values already in the
# environment win over this file.
#
# `.env` is gitignored; never commit a real key.

# --- Required ---
# Z.ai API key (https://z.ai -> Dashboard -> API Keys).
GLM_API_KEY=

# Optional: OpenRouter (Anthropic skin). When set, slash-namespaced model ids
# (e.g. anthropic/claude-opus-4, z-ai/glm-4.7) route to OpenRouter via Bearer
# auth. Leave empty to disable.
OPENROUTER_API_KEY=

# --- Proxy ---
# Listen port for the local proxy.
PROXY_PORT=4000
# Backend used when a request's model matches no prefix. "claude" or "glm".
DEFAULT_BACKEND=claude

# --- Logging / debug ---
# File the SessionStart hook redirects proxy stdout/stderr to.
PROXY_LOG=/tmp/cc-proxy.log
# Set to 1 to log per-request metadata and routing detail.
PROXY_DEBUG=
